# Model weights / adapters / configs — never committed (large, and
# license-encumbered base weights must not be redistributed). Ignore
# everything under checkpoints/ except the README; adapter_config.json and
# pipeline_state.json are orphans without their gitignored weights.
checkpoints/*
!checkpoints/README.md

# Data — downloaded at runtime, not vendored.
data/cache/
data/*.jsonl
data/*.arrow
*.parquet

# Python
__pycache__/
*.pyc
.venv/
.ipynb_checkpoints/

# Local secrets / kaggle creds
kaggle.json
.env
